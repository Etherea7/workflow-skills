# Shell and Node scripts must stay LF — CRLF breaks bash execution on Windows (Git Bash).
* text=auto
*.sh text eol=lf
*.mjs text eol=lf
*.md text
*.yml text
# Committed eval evidence must stay byte-exact — tests hash these artifacts,
# and autocrlf checkout conversion would drift the hashes on Windows.
evals/*/evidence/artifacts/** -text
